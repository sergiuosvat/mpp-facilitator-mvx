{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^mppx/(.*)$": "<rootDir>/mppx.mock.js",
    "^mppx-multiversx/(.*)$": "<rootDir>/mppx.multiversx.mock.js"
  }
}
