## Server
PORT=3000

## Prisma (SQLite)
# Use the included sqlite file in this repo:
DATABASE_URL="file:./dev.db"

## MPP / x402 core
# Required (app will not start without it)
MPP_SECRET_KEY="CHANGE_ME_TO_A_RANDOM_SECRET"

# Devnet defaults
MPP_CHAIN_ID="D"
MPP_DEFAULT_CURRENCY="EGLD"
MPP_TOKEN_DECIMALS="18"
MPP_REALM="agentic-payments-mvx"
MPP_RELAY_RATE_LIMIT="100"

# Optional, but recommended for proper voucher verification against `mpp-session-mvx`
# If not set, voucher signature verification is skipped.
MPP_SESSION_CONTRACT="erd1..."

## MultiversX providers (devnet defaults)
MVX_API_URL="https://devnet-api.multiversx.com"
NETWORK_PROVIDER="https://devnet-gateway.multiversx.com"
RELAYER_PEM_PATH="./wallet.pem"

## Discovery/OpenAPI server URL (optional)
MPP_BASE_URL="http://localhost:3000"

